# ============ Database (host-installed MySQL) ============
# Using a native MySQL service on the host, NOT the docker container.
# Database `mediverse` and user `mediverse` are created via:
#   mysql -u root -p -e "CREATE DATABASE mediverse; CREATE USER 'mediverse'@'localhost' IDENTIFIED BY '<pwd>'; GRANT ALL ON mediverse.* TO 'mediverse'@'localhost';"

# ============ Backend (Spring Boot) ============
DB_URL=jdbc:mysql://localhost:3306/mediverse
DB_USER=mediverse
DB_PASSWORD=mediversepass

JWT_SECRET=change-me-to-a-long-random-string-of-at-least-32-chars
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=7

# Google OAuth — required for Google sign-in. Spring maps these to google.oauth.* in application.yml.
# Never commit real credentials; copy vars from Google Cloud Console into your local .env only.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Redirect URI to add in Google Cloud Console (OAuth 2.0 Client, Web):
#   http://localhost:8080/login/oauth2/code/google

AWS_REGION=us-east-1
AWS_S3_BUCKET=mediverse-uploads
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

GEMINI_API_KEY=
# If generateContent returns 404, set ids from ListModels (see application.yml comment).
GEMINI_CHAT_MODEL=gemini-2.5-flash
GEMINI_VISION_MODEL=gemini-2.5-pro

# Mail (MailHog defaults — see docker-compose)
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@mediverse.local

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Comma-separated list of emails that can access /admin/verifications
# (used only for doctor verification — there is no full ADMIN role)
ADMIN_EMAILS=admin@mediverse.local

# --- Google Calendar API (optional: video Meet + calendar invites on book/approve) ---
# Enable Calendar API in GCP. GOOGLE_CALENDAR_ENABLED=true still requires credentials below.
# OAuth refresh token (same GCP client): good for a user calendar + Meet. Or service account + Workspace delegation.
GOOGLE_CALENDAR_ENABLED=false
GOOGLE_CALENDAR_APP_NAME=MediVerse
# OAuth path (set all three; leave service account empty):
GOOGLE_CALENDAR_OAUTH_CLIENT_ID=
GOOGLE_CALENDAR_OAUTH_CLIENT_SECRET=
GOOGLE_CALENDAR_OAUTH_REFRESH_TOKEN=
# Or service account JSON file path (file: or classpath:):
GOOGLE_CALENDAR_SERVICE_ACCOUNT_JSON=
# Workspace only — user to impersonate:
GOOGLE_CALENDAR_DELEGATED_USER=
# Override calendar id (default: primary for OAuth/delegation, else SA email):
GOOGLE_CALENDAR_CALENDAR_ID=

NEXT_PUBLIC_API_BASE_URL=http://localhost:8080/api
NEXT_PUBLIC_GOOGLE_OAUTH_URL=http://localhost:8080/oauth2/authorization/google
# Optional: mirror backend mediverse.appointment.booking-horizon-days (default 7)
# NEXT_PUBLIC_BOOKING_HORIZON_DAYS=7
# Browser key: Maps JavaScript API + Places (Autocomplete) + Geocoder (reverse geocode when clicking the map).
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
